{
  "name": "watermelon",
  "private": true,
  "version": "0.1.0",
  "description": "Windows desktop app for managing custom League of Legends skins.",
  "type": "module",
"scripts": {

  "predev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clear-port.ps1",

  "dev": "vite",

  "build": "tsc && vite build",

  "preview": "vite preview",

  "tauri": "tauri",



  "tauri:build": "tauri build",

  "sign:exe": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& 'C:\\Program Files (x86)\\Windows Kits\\10\\bin\\10.0.26100.0\\x64\\signtool.exe' sign /fd SHA256 /td SHA256 /tr http://timestamp.certum.pl /a 'src-tauri\\target\\release\\watermelon.exe'\"",

  "run:signed": "powershell -NoProfile -Command \"& 'src-tauri\\target\\release\\watermelon.exe' 2>&1 | Tee-Object -FilePath logs.txt\"",

  "signed:run": "pnpm tauri:build && pnpm sign:exe && pnpm run:signed"

},
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
